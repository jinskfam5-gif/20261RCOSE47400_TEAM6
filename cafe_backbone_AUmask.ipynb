      "source": [
        "## 7. Initialize Model, Optimizer, Scheduler"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 13,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "0Y2mGhVlC_MX",
        "outputId": "d10a5ec7-bd19-49be-82c3-c0869ea01fa0"
      },
