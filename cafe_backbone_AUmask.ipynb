        "                f'ours_final_{TRAIN_DATASET_NAME}.pth')                       # ✅\n",
        "    torch.save({'model_state_dict': model.state_dict()},\n",
        "                os.path.join(SAVE_DIR, f'ours_final_{TRAIN_DATASET_NAME}.pth'))     # ✅\n",
