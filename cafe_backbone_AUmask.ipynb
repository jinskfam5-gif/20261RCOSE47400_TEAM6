    {
      "cell_type": "markdown",
      "metadata": {
        "id": "_iSCAR8tC_MX"
      },
      "source": [
        "## 8. Train and Test Functions"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "from collections import Counter\n",
        "label_counts = Counter(full_train_dataset.labels)\n",
        "counts = torch.tensor([label_counts[i] for i in range(NUM_CLASSES)], dtype=torch.float)\n",
        "class_weights = counts.sum() / (NUM_CLASSES * counts)\n",
        "class_weights = torch.clamp(class_weights, max=3.0).to(device)"
      ],
      "metadata": {
        "id": "MjpnuZ_jVEFR"
      },
      "execution_count": 14,
      "outputs": []
    },
    {
      "cell_type": "code",
      "execution_count": 15,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "YGcI0vQwC_MX",
        "outputId": "187fc487-ae78-45ae-e9ed-d310f1f3d7d6"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Train and test functions ready.\n"
          ]
        }
      ],
      "source": [
        "def train_one_epoch(model, train_loader, optimizer, scheduler, device, AU_TABLE):\n",
        "    model.train()\n",
        "    running_loss = 0.0\n",
        "    correct_sum = 0\n",
        "\n",
        "    for imgs, labels, _, _ in train_loader:\n",
        "        imgs, labels = imgs.to(device), labels.to(device)\n",
        "\n",
        "        # 1. 모델에서 spatial_map까지 받아옴\n",
        "        output, MC_loss, spatial_map = model(imgs, clip_model, labels, phase='train')\n",
        "\n",
        "        # 2. 각종 Loss 계산\n",
        "        loss_cls = nn.CrossEntropyLoss()(output, labels)\n",
        "        loss_au  = au_alignment_loss(spatial_map, labels, AU_TABLE) # AU Loss 추가\n",
        "\n",
        "        # 3. 최종 Loss 합산 (0.5 가중치 적용)\n",
        "        loss = loss_cls + 5 * MC_loss[1] + 1.5 * MC_loss[0] + 0.5 * loss_au\n",
        "\n",
        "        optimizer.zero_grad()\n",
        "        loss.backward()\n",
        "        optimizer.step()\n",
        "\n",
        "        _, predicts = torch.max(output, 1)\n",
        "        correct_sum += torch.eq(predicts, labels).sum()\n",
        "        running_loss += loss.item()\n",
        "\n",
        "    scheduler.step()\n",
        "    return (correct_sum.float() / len(train_loader.dataset)).item(), running_loss / len(train_loader)\n",
        "\n",
        "\n",
        "def test_model(model, test_loader, device):\n",
        "    \"\"\"\n",
        "    Evaluation — uses only l_cls path (no separation/diverse at test time).\n",
        "    \"\"\"\n",
        "    model.eval()\n",
        "    with torch.no_grad():\n",
        "        running_loss = 0.0\n",
        "        iter_cnt     = 0\n",
        "        correct_sum  = 0\n",
        "        data_num     = 0\n",
        "\n",
        "        for imgs, labels, indexes, imgs_flip in test_loader:\n",
        "            imgs   = imgs.to(device)\n",
        "            labels = labels.to(device)\n",
        "\n",
        "            outputs, _ = model(imgs, clip_model, labels, phase='test')\n",
        "            loss       = nn.CrossEntropyLoss()(outputs, labels)\n",
        "\n",
        "            iter_cnt  += 1\n",
        "            _, predicts = torch.max(outputs, 1)\n",
        "            correct_sum += torch.eq(predicts, labels).sum()\n",
        "            running_loss += loss\n",
        "            data_num     += outputs.size(0)\n",
        "\n",
        "        running_loss = running_loss / iter_cnt\n",
        "        test_acc     = correct_sum.float() / float(data_num)\n",
        "\n",
        "    return test_acc.item(), running_loss.item()\n",
        "\n",
        "\n",
        "print('Train and test functions ready.')"
      ]
    },
